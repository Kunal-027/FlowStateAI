# =============================================================================
# API keys – copy this file to .env and fill in your keys (do not commit .env)
# =============================================================================

# --- Hugging Face (primary LLM – used first by the bridge AI step interpreter) ---
# Get your token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Optional: same as above (bridge checks both)
# HF_TOKEN=

# Optional: override model (default: Qwen/Qwen2.5-72B-Instruct)
# HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- Claude / Anthropic (fallback only – used when Hugging Face fails or no HF key) ---
# Add your key for a reliable fallback. Used only after HF is tried first.
ANTHROPIC_API_KEY=

# Optional: override Claude model (default: claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
