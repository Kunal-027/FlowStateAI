{
  "name": "flowstate-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "postinstall": "PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=true npx playwright install chromium",
    "lint": "next lint",
    "bridge": "node bridge/server.js",
    "bridge:watch": "nodemon --watch bridge --ext js bridge/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run bridge:watch\"",
    "kill-ports": "node scripts/kill-ports.js 3000 4000",
    "clean-and-kill": "node scripts/clean-and-kill.js",
    "clean": "node scripts/clean-next.js",
    "clean:trace": "node scripts/clean-trace.js",
    "dev:fresh": "node scripts/kill-ports.js 3000 4000 && node scripts/clean-next.js && npm run dev:all",
    "fresh": "node scripts/kill-ports.js 3000 4000 && node scripts/clean-next.js && next dev -p 3000"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@huggingface/inference": "^4.13.14",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "playwright": "^1.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.0"
  }
}
